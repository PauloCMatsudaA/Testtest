# ── OpenAI ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── WhatsApp Cloud API (Meta) ────────────────────────────
# Obtido no painel do Meta for Developers
WHATSAPP_PHONE_NUMBER_ID=1234567890
WHATSAPP_ACCESS_TOKEN=EAAxxxxxx
WHATSAPP_VERIFY_TOKEN=episee_webhook_token_qualquer_string_segura

# ── Configurações do chatbot ─────────────────────────────
GPT_MODEL=gpt-4o
MAX_HISTORY_MESSAGES=10       # Número de turnos de conversa mantidos por usuário
MAX_TOKENS_RESPONSE=800

# ── RAG ──────────────────────────────────────────────────
FAISS_INDEX_PATH=data/faiss_index.bin
NR6_CHUNKS_PATH=data/nr6_chunks
TOP_K_CHUNKS=4                # Quantos trechos da NR-6 injetar no contexto
